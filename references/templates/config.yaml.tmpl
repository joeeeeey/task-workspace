version: 1
workspace_mode: repo-root
execution_root: "."
task_state_root: ".agent-harness/tasks"
current_task_file: ".agent-harness/current"
default_launcher: none
single_owner_per_task: true

repo:
  name: "{{ repo_name }}"
  root: "{{ repo_root }}"
  detected_stack:
{{ detected_stack_yaml }}
  default_commands:
{{ commands_yaml }}

notes:
  - "Run project commands from the repository root, not from task state directories."
  - "Task records store memory only; source code stays in the repository workspace."

