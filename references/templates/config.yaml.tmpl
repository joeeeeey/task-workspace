version: 2
workspace_mode: task-workspace
source_repo_root: "{{ source_repo_root }}"
task_state_root: ".task-workspace/tasks"
current_task_file: ".task-workspace/current"
tmp_root: "{{ tmp_root }}"
default_launcher: none
single_owner_per_task: true

repo:
  name: "{{ repo_name }}"
  remote_url: "{{ remote_url }}"
  detected_stack:
{{ detected_stack_yaml }}
  default_commands:
{{ commands_yaml }}

notes:
  - "Bootstrap from the source repo root."
  - "Launch the follow-up agent from the task workspace under .task-workspace/tasks/<task-id>."
  - "Code edits happen in the /tmp code workspace, not in the source repo root and not in the task workspace."
